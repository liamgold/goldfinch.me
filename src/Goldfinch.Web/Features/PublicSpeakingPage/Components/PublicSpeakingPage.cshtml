@using Goldfinch.Core.PublicSpeaking
@model PublicSpeakingModel

@{
    var totalTalks = Model.Years.Sum(y => y.SpeakingEngagements.Count);
    var withRecording = Model.Years.SelectMany(y => y.SpeakingEngagements).Count(e => !string.IsNullOrWhiteSpace(e.RecordingLink));
    var countries = Model.Years
        .SelectMany(y => y.SpeakingEngagements)
        .Select(e => e.EventLocation ?? "")
        .Where(l => !string.IsNullOrWhiteSpace(l) && !l.Contains("Online", StringComparison.OrdinalIgnoreCase))
        .Select(l => l.Split(',').Last().Trim())
        .Distinct()
        .Count();
    var firstYear = Model.Years.Select(y => y.Year).DefaultIfEmpty(DateTime.UtcNow.Year).Min();
}

<section class="speaking-page fadeup">
    <div class="speaking-intro">
        <span class="mono-label mono-label--accent">~/speaking</span>
        <h1 class="mono">@Model.Page.BaseContentTitle</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Page.BaseContentShortDescription))
        {
            <p>@Model.Page.BaseContentShortDescription</p>
        }
        else
        {
            <p>Talks, webinars, and user-group appearances — mostly around Xperience by Kentico and how I ship on it.</p>
        }
    </div>

    @* Intro widgets if the editable area has any — keep rendering for back-compat. *@
    <div class="post-body">
        <editable-area area-identifier="PublicSpeaking" />
    </div>

    <div class="speaking-stats">
        <div class="speaking-stats__item">
            <div class="speaking-stats__value">@totalTalks.ToString("00")</div>
            <span class="speaking-stats__label">talks given</span>
        </div>
        <div class="speaking-stats__item">
            <div class="speaking-stats__value">@countries.ToString("00")</div>
            <span class="speaking-stats__label">countries</span>
        </div>
        <div class="speaking-stats__item">
            <div class="speaking-stats__value">@withRecording.ToString("00")</div>
            <span class="speaking-stats__label">recordings</span>
        </div>
        <div class="speaking-stats__item">
            <div class="speaking-stats__value">@firstYear</div>
            <span class="speaking-stats__label">first talk</span>
        </div>
    </div>

    @foreach (var group in Model.Years)
    {
        <section class="speaking-year">
            <header class="section-header">
                <div class="section-header__body">
                    <span class="section-header__n">// @group.Year</span>
                    <h2>@group.Year</h2>
                </div>
            </header>

            <div class="speaking-grid @(group.SpeakingEngagements.Count == 1 ? "speaking-grid--single" : "")">
                @foreach (var talk in group.SpeakingEngagements)
                {
                    var isRecording = !string.IsNullOrWhiteSpace(talk.RecordingLink);
                    var cardTag = isRecording ? "a" : "article";
                    var href = isRecording ? talk.RecordingLink : null;

                    @if (isRecording)
                    {
                        <a class="talk-card" href="@href" target="_blank" rel="noopener">
                            @await Html.PartialAsync("PartialViews/TalkCardBody", talk)
                        </a>
                    }
                    else
                    {
                        <article class="talk-card">
                            @await Html.PartialAsync("PartialViews/TalkCardBody", talk)
                        </article>
                    }
                }
            </div>
        </section>
    }
</section>
