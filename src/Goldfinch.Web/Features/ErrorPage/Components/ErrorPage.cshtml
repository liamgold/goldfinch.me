@model Goldfinch.Core.ContentTypes.ErrorPage

<section class="error-page fadeup">
    <div class="mono-label mono-label--accent">~/error</div>
    <h1 class="mono">@Model.ErrorTitle</h1>
    <div class="post-body">
        @Html.Raw(Model.ErrorText)
    </div>
    <div class="actions">
        <a class="btn btn--primary" href="/">Back home</a>
        <a class="btn" href="/blog">Blog posts</a>
    </div>
    <p class="mono error-page__hint">
        Tip — press <kbd class="palette-kbd">⌘</kbd><kbd class="palette-kbd">K</kbd> to search posts.
    </p>
</section>
