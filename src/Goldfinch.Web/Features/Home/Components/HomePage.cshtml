@using Goldfinch.Web.Features.Home
@model HomePageViewModel

@functions {
    @* Launch toggle: now.md side panel is hidden at launch. Uncomment the aside
       in the hero markup + restore this data + swap hero-grid--solo for --with-now.
       TODO: Move "Now" rows into CMS (either a repeater field on Home or a JSON file).
    (string Label, string Value, string? Sub)[] nowRows = new[]
    {
        ("Reading",     "Designing Data-Intensive Applications",     (string?)"Martin Kleppmann"),
        ("Shipping",    "Stripe provider for Xperience",             "tagging v0.3 next week"),
        ("Playing with","Claude Code agents in .NET repos",          "automating smoke tests"),
        ("Listening",   "Software Engineering Daily",                "episode: LLM-assisted refactors"),
    };
    *@

    @* "Browse by topic" data is hidden with its section until taxonomy is
       wired up. Restore this array + uncomment the section below.
    (string Slug, string Label, int Count)[] topicTags = new[]
    {
        ("xperience",   "Xperience",     8),
        ("saas",        "Kentico SaaS",  3),
        ("umbraco",     "Umbraco",       2),
        ("ai",          "AI tooling",    3),
        ("open-source", "Open source",   3),
        (".net",        ".NET",          2),
        ("commerce",    "Commerce",      2),
        ("security",    "Security",      1),
    };
    *@

    string FirstTag(string title) => "post";
}

@section schema {
    @* no-op — home doesn't emit structured data yet *@
}

<div class="fadeup">
    <section class="hero">
        @* now.md side panel is hidden at launch — restore --with-now class
           + uncomment the <aside> block below when a content source is ready. *@
        <div class="hero-grid hero-grid--solo">
            <div>
                <div class="hero-prompt mono"><span class="dollar">$ </span>whoami</div>
                <h1 class="hero-h1 mono">
                    @if (!string.IsNullOrWhiteSpace(Model.Page?.Heading))
                    {
                        @Model.Page.Heading
                    }
                    else
                    {
                        <text>Liam Goldfinch.</text>
                    }
                    <br />
                    <span class="line-muted">writing about </span><span class="line-accent">Kentico</span><span class="line-muted"> &amp; </span><span class="line-accent">.NET</span><span class="cursor"></span>
                </h1>

                <div class="hero-lede">
                    @if (!string.IsNullOrWhiteSpace(Model.Page?.MainContent))
                    {
                        @Html.Raw(Model.Page.MainContent)
                    }
                    else
                    {
                        <p>Principal Systems Developer at <a href="/about">IDHL</a>, Kentico MVP since 2022. Long-form notes on Xperience by Kentico, the .NET ecosystem, and the tooling I use to ship.</p>
                    }
                </div>

                <div class="hero-buttons">
                    <a class="btn btn--primary" href="/blog"><icon name="book" size="15" /> <span>Read the blog</span></a>
                    <a class="btn" href="/about"><icon name="user" size="15" /> <span>About me</span></a>
                    <a class="btn" href="/public-speaking"><icon name="mic" size="15" /> <span>Speaking</span></a>
                </div>

                <div class="hero-stats">
                    <div>
                        <div class="hero-stats__value mono">@Model.YearsCoding.ToString("00")y</div>
                        <span class="hero-stats__label mono">years coding</span>
                    </div>
                    @if (Model.FirstPostYear.HasValue)
                    {
                        <div>
                            <div class="hero-stats__value mono">@Model.FirstPostYear.Value</div>
                            <span class="hero-stats__label mono">blogging since</span>
                        </div>
                    }
                    <div>
                        <div class="hero-stats__value mono">@Model.KenticoMvpCount.ToString("00")×</div>
                        <span class="hero-stats__label mono">Kentico MVP</span>
                    </div>
                    <div>
                        <div class="hero-stats__value mono">@Model.TotalPostCount.ToString("00")</div>
                        <span class="hero-stats__label mono">posts published</span>
                    </div>
                </div>
            </div>

            @*
            <aside class="now-panel">
                <div class="now-panel__head">
                    <span class="post-card__dots"><span></span><span></span><span></span></span>
                    <span class="now-panel__filename mono">now.md</span>
                    <span class="now-panel__updated mono">updated 2d ago</span>
                </div>
                <div class="now-panel__body">
                    <div class="now-panel__title mono">
                        <span class="hash">#</span>
                        <span>What I'm doing now</span>
                    </div>
                    <p class="now-panel__lede">A snapshot, not a timeline.</p>
                    <ul class="now-list">
                        @foreach (var row in nowRows)
                        {
                            <li class="now-list__row">
                                <div class="now-list__label">@row.Label</div>
                                <div>
                                    <div class="now-list__value">@row.Value</div>
                                    @if (!string.IsNullOrWhiteSpace(row.Sub))
                                    {
                                        <div class="now-list__sub">// @row.Sub</div>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </aside>
            *@
        </div>
    </section>

    @if (Model.FeaturedPost is not null)
    {
        <section class="home-section">
            <header class="section-header">
                <div class="section-header__body">
                    <span class="section-header__n">// 01</span>
                    <h2>Featured post</h2>
                    <p class="section-header__sub mono">Pinned. Start here.</p>
                </div>
            </header>

            @{
                // Decorative code-editor motif. Row widths cycle through a fixed palette.
                // Colors live in global.css (.motif-col-N) to avoid CSP inline-style violations.
                var codeColWidths = new[] { 24, 46, 70, 90, 30, 60 };
            }

            <a class="featured-card" href="@Model.FeaturedPost.Url">
                <div class="featured-card__thumb">
                    <svg class="featured-card__motif" viewBox="0 0 320 220" preserveAspectRatio="xMidYMid meet" overflow="hidden" aria-hidden="true">
                        <rect x="0" y="0" width="320" height="220" fill="var(--bg)" stroke="var(--border)" />
                        <rect x="0" y="0" width="320" height="22" fill="var(--bg-2)" />
                        <circle cx="12" cy="11" r="4" fill="#f87171" opacity=".7" />
                        <circle cx="28" cy="11" r="4" fill="#fbbf24" opacity=".7" />
                        <circle cx="44" cy="11" r="4" fill="#86efac" opacity=".7" />
                        <text x="64" y="15" class="motif-filename">@(Model.FeaturedPost.Filename.Length > 34 ? Model.FeaturedPost.Filename[..31] + "…" : Model.FeaturedPost.Filename)</text>
                        @for (var i = 0; i < 9; i++)
                        {
                            var lineY = 44 + i * 17;
                            var take = 2 + (i % 3);
                            var x = 12;
                            <g>
                                <text x="4" y="@lineY" class="motif-linenum">@((i + 1).ToString("00"))</text>
                                @for (var k = 0; k < take; k++)
                                {
                                    <rect x="@(20 + x)" y="@(lineY - 7)" width="@codeColWidths[k]" height="8" class="motif-col-@k" opacity=".35" />
                                    x += codeColWidths[k] + 6;
                                }
                            </g>
                        }
                    </svg>
                    <span class="featured-card__pin mono"><icon name="pin" size="12" /> Pinned post</span>
                </div>
                <div class="featured-card__body">
                    <div class="featured-card__meta">
                        <span>@Model.FeaturedPost.PublishedOn.ToString("dd MMM yyyy")</span>
                        <span class="featured-card__sep">·</span>
                        <span class="meta-chip"><icon name="clock" size="12" /> @Model.FeaturedPost.ReadingMinutes min read</span>
                    </div>
                    <h3 class="featured-card__title">@Model.FeaturedPost.Title</h3>
                    <p class="featured-card__summary">@Model.FeaturedPost.Summary</p>
                    <div class="featured-card__cta">
                        <span>Read the post</span>
                        <icon name="arrowR" size="15" />
                    </div>
                </div>
            </a>
        </section>
    }

    @if (Model.RecentPosts.Count > 0)
    {
        <section class="home-section">
            <header class="section-header">
                <div class="section-header__body">
                    <span class="section-header__n">// 02</span>
                    <h2>Recent posts</h2>
                </div>
                <a class="section-link mono section-header__right" href="/blog">All posts <icon name="arrowR" size="14" /></a>
            </header>
            <div class="post-grid">
                @foreach (var post in Model.RecentPosts)
                {
                    <a class="post-card" href="@post.Url">
                        <div class="post-card__head">
                            <span class="post-card__dots"><span></span><span></span><span></span></span>
                            <span class="post-card__filename">@post.Filename</span>
                            <span class="post-card__mins">@post.ReadingMinutes min</span>
                        </div>
                        <div class="post-card__thumb">
                            <partial name="PartialViews/_PostCardDots" />
                            <span class="post-card__thumb-text mono">#@FirstTag(post.Title)</span>
                        </div>
                        <div class="post-card__body">
                            <div class="post-card__meta">
                                <span>@post.PublishedOn.ToString("dd MMM yyyy")</span>
                            </div>
                            <h3 class="post-card__title">@post.Title</h3>
                            <p class="post-card__summary">@post.Summary</p>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @* "Browse by topic" hidden until a Tag content type is wired up — the
       chips currently link to /blog?tag=slug, which no-ops. Restore the
       topicTags data + this section together when taxonomy lands.
    <section class="home-section">
        <header class="section-header">
            <div class="section-header__body">
                <span class="section-header__n">// 03</span>
                <h2>Browse by topic</h2>
                <p class="section-header__sub mono">Filter the archive by topic.</p>
            </div>
        </header>
        <div class="topic-chips">
            @foreach (var tag in topicTags)
            {
                <a class="tag-chip mono" href="/blog?tag=@tag.Slug">
                    <span class="tag-chip__hash">#</span>
                    <span>@tag.Label</span>
                    <span class="tag-chip__count mono">@tag.Count</span>
                </a>
            }
        </div>
    </section>
    *@


</div>
