@using Microsoft.AspNetCore.Mvc.Localization
@using Kentico.Activities.Web.Mvc
@using Kentico.OnlineMarketing.Web.Mvc
<!--
  Goldfinch.me — if you're reading this, you're either me or someone very cool.
-->
<!DOCTYPE html>
<html lang="en-GB" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0c0d0f">
    <vc:page-title />

    <link rel="preload" href="/fonts/jetbrains-mono-variable-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/geist-variable.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="stylesheet" asp-href-include="/sitefiles/dist/assets/global-*.css" />
    @RenderSection("styles", required: false)

    <link rel="sitemap" type="application/xml" href="/sitemap.xml">
    <link rel="alternate" type="application/rss+xml" title="Goldfinch.me — RSS" href="/rss.xml">
    <link rel="icon" href="/favicon.ico" sizes="48x48">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-96x96.png" type="image/png" sizes="96x96">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">

    <page-builder-mode>
        <page-builder-styles />
    </page-builder-mode>

    <vc:canonical />
    <vc:seo />
    @RenderSection("schema", required: false)
</head>
<body>
    <a class="skip-link" href="#main">Skip to content</a>

    <vc:header />

    <main id="main">
        @RenderBody()
    </main>

    <partial name="PartialViews/Footer" />

    <partial name="PartialViews/MobileDrawer" />

    <div id="palette-root"></div>

    <page-builder-mode>
        <page-builder-scripts />
    </page-builder-mode>

    @RenderSection("scripts", required: false)
    <script type="module" defer asp-src-include="/sitefiles/dist/assets/main-*.js"></script>
</body>
</html>
