@using Goldfinch.Web.Components.ViewComponents.LatestBlogPosts
@model LatestBlogPostsViewModel

<section class="home-section">
    <header class="section-header">
        <div class="section-header__body">
            <span class="section-header__n">// related</span>
            <h2>@Model.Title</h2>
        </div>
    </header>
    <div class="post-grid">
        @foreach (var post in Model.BlogPosts)
        {
            <partial name="PartialViews/BlogPost" model="post" />
        }
    </div>
</section>
