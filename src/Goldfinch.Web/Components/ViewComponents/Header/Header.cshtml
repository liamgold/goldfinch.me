@using Goldfinch.Web.Components.ViewComponents.Header
@model HeaderViewModel

<header class="header" data-scrolled="false">
    <div class="header-inner">
        <a class="brand" href="/" aria-label="Goldfinch.me home">
            <span class="brand-mark" aria-hidden="true">~</span>
            <span class="brand-text mono">
                <span class="brand-name">liam<span class="brand-at">@@</span>goldfinch</span>
                <span class="brand-sub">~/blog · main</span>
            </span>
        </a>

        <nav class="nav-desktop" aria-label="Primary">
            @foreach (var item in Model.NavigationItems)
            {
                <a class="nav-tab"
                   href="@item.Url"
                   aria-current="@(item.IsActive ? "page" : null)">
                    <icon name="@item.Icon" size="14" />
                    <span>@item.FileLabel</span>
                </a>
            }
        </nav>

        <span class="header-spacer"></span>

        <button class="search-desktop" type="button" data-palette-open aria-label="Open command palette">
            <icon name="search" size="13" />
            <span>Search posts…</span>
            <span class="kbd-hint" aria-hidden="true">
                <kbd class="palette-kbd">⌘</kbd><kbd class="palette-kbd">K</kbd>
            </span>
        </button>

        <button type="button" class="icon-btn search-mobile" data-palette-open aria-label="Search">
            <icon name="search" size="18" />
        </button>
        <button type="button"
                class="icon-btn menu-mobile"
                data-drawer-toggle
                aria-label="Open menu"
                aria-expanded="false"
                aria-controls="mobile-drawer">
            <icon name="menu" size="18" />
        </button>
    </div>
</header>
